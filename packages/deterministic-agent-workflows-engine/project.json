{
  "name": "deterministic-agent-workflows-engine",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/deterministic-agent-workflows-engine/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/deterministic-agent-workflows-engine/tsconfig.json && node tools/rewrite-relative-import-extensions.mjs packages/deterministic-agent-workflows-engine/dist"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/deterministic-agent-workflows-engine/tsconfig.json --noEmit"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint packages/deterministic-agent-workflows-engine/src --ext .ts"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --config packages/deterministic-agent-workflows-engine/vitest.config.mts"
      }
    }
  }
}
