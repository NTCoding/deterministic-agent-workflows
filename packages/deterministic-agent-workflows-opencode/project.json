{
  "name": "deterministic-agent-workflows-opencode",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/deterministic-agent-workflows-opencode/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/deterministic-agent-workflows-opencode/tsconfig.json && node tools/rewrite-relative-import-extensions.mjs packages/deterministic-agent-workflows-opencode/dist"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/deterministic-agent-workflows-opencode/tsconfig.json --noEmit"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint packages/deterministic-agent-workflows-opencode/src --ext .ts"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "dependsOn": ["build", "^build"],
      "options": {
        "command": "pnpm --dir packages/deterministic-agent-workflows-opencode exec node smoke-test.mjs"
      }
    }
  }
}
