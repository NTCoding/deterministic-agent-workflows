{
  "name": "deterministic-agent-workflows-control-center",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "description": "Real-time web-based analytics dashboard for deterministic workflow event stores",
  "bin": {
    "workflow-control-center": "./src/shell/main.ts"
  },
  "scripts": {
    "start": "npx tsx src/shell/main.ts",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "deps": "depcruise src --config .dependency-cruiser.cjs",
    "lint": "eslint src --ext .ts,.tsx --config eslint.config.mjs",
    "test": "vitest run --coverage --config vitest.config.mts",
    "test:watch": "vitest --config vitest.config.mts",
    "test:e2e": "playwright test",
    "build": "tsc --noEmit && vite build"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@nt-ai-lab/deterministic-agent-workflow-engine": "workspace:*",
    "@nt-ai-lab/deterministic-agent-workflow-event-store": "workspace:*",
    "@tanstack/react-query": "^5.62.16",
    "@tanstack/react-query-devtools": "^5.62.16",
    "@tanstack/react-router": "^1.95.1",
    "clsx": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "tailwind-variants": "^0.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/router-devtools": "^1.95.1",
    "@tanstack/router-vite-plugin": "^1.95.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "dependency-cruiser": "^17.3.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^25.0.1",
    "msw": "^2.7.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.7",
    "vitest": "^2.1.9"
  }
}
