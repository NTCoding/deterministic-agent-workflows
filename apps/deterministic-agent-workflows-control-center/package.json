{
  "name": "deterministic-agent-workflows-control-center",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Real-time web-based analytics dashboard for deterministic workflow event stores",
  "bin": {
    "workflow-control-center": "./src/main.ts"
  },
  "scripts": {
    "start": "npx tsx src/main.ts",
    "typecheck": "tsc --noEmit",
    "deps": "depcruise src --config .dependency-cruiser.cjs",
    "lint": "echo 'no lint configured'",
    "test": "vitest run --coverage",
    "build:ui": "node build-ui.mjs",
    "dev:ui": "node build-ui.mjs --watch"
  },
  "dependencies": {
    "@nick-tune/deterministic-agent-workflows-engine": "workspace:*",
    "@nick-tune/deterministic-agent-workflows-event-store": "workspace:*",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "dependency-cruiser": "^17.3.8",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
