{
  "name": "deterministic-agent-workflows-control-center",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/deterministic-agent-workflows-control-center/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir apps/deterministic-agent-workflows-control-center exec tsc -p tsconfig.json --noEmit && pnpm --dir apps/deterministic-agent-workflows-control-center exec vite build"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir apps/deterministic-agent-workflows-control-center exec vite"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir apps/deterministic-agent-workflows-control-center exec tsc -p tsconfig.json --noEmit"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir apps/deterministic-agent-workflows-control-center exec eslint src --ext .ts,.tsx --config eslint.config.mjs"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir apps/deterministic-agent-workflows-control-center exec vitest run --coverage --config vitest.config.mts"
      }
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir apps/deterministic-agent-workflows-control-center exec playwright test"
      }
    }
  }
}
