{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "packages"
  },
  "namedInputs": {
    "sharedGlobals": [],
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": [
      "default",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/**/*.test.ts"
    ]
  },
  "targetDefaults": {
    "build": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "lint": {
      "cache": true,
      "inputs": ["default", "{workspaceRoot}/eslint.config.mjs"]
    },
    "test": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["default", "^production"]
    },
    "typecheck": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["default", "^production"]
    }
  },
  "release": {
    "projectsRelationship": "independent",
    "projects": [
      "packages/*"
    ],
    "version": {
      "preVersionCommand": "pnpm exec nx run-many -t build --projects=packages/*",
      "conventionalCommits": true,
      "fallbackCurrentVersionResolver": "disk",
      "updateDependents": "auto",
      "generatorOptions": {
        "installIgnoreScripts": true
      }
    },
    "changelog": {
      "projectChangelogs": false,
      "workspaceChangelog": {
        "file": "CHANGELOG.md",
        "createRelease": "github"
      }
    },
    "git": {
      "commit": true,
      "commitMessage": "chore(release): {version} [skip ci]",
      "tag": true,
      "push": true
    }
  }
}
